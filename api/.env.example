# Все эти переменные регистрируются через `wrangler secret put NAME` (а не .env).
# Этот файл — справочный список для маркетолога / разработчика.

# --- AlphaCRM ---
# Endpoint v2 API. Пример: https://kiberonenabchln.s20.online/v2api/lead/index
ALPHACRM_API_URL=

# Токен X-ALFACRM-TOKEN (получить в настройках интеграций AlphaCRM)
ALPHACRM_API_KEY=

# ID источника лида «листовка-подарок 5000 ₽». Создать в AlphaCRM:
#   Настройки → Источники → Добавить «Листовка 5000 ₽»
# и подставить полученный numeric ID.
ALPHACRM_LEAD_SOURCE_ID=

# ID локаций (филиалов) по городам. Берутся в AlphaCRM в настройках филиалов.
ALPHACRM_BRANCH_ID_CHELNY=
ALPHACRM_BRANCH_ID_NIZHNEKAMSK=
ALPHACRM_BRANCH_ID_KAZAN=
ALPHACRM_BRANCH_ID_ELABUGA=
ALPHACRM_BRANCH_ID_KRASNODAR=
ALPHACRM_BRANCH_ID_SURGUT=
ALPHACRM_BRANCH_ID_PERM=

# --- Telegram (дублирующее уведомление) ---
# Можно использовать существующего бота (anketa-bot/salary_bot) либо завести нового.
# Бот должен быть добавлен в чат, куда уходят уведомления (личка владельца = 400383551).
TG_BOT_TOKEN=
TG_CHAT_ID=400383551

# --- Сервис ---
# Любая случайная строка, для GET /api/stats?token=...
STATS_TOKEN=

# Origin лендинга для CORS. Задаётся в wrangler.toml [vars] или через secret.
ALLOWED_ORIGIN=https://podarok.it-kiber.ru
